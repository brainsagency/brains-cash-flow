# Copy to .env.local and fill in. NEVER commit real secrets — .env* is gitignored.
# This is bank-connected data; tokens live in Vercel/Supabase secret stores.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- QuickBooks Online (OAuth2, Intuit developer app) ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox   # sandbox | production
# Must exactly match a Redirect URI registered in the Intuit app (Keys & OAuth).
QBO_REDIRECT_URI=http://localhost:3000/api/connect/qbo/callback
# realmId + tokens are captured at connect time and stored per-connection.

# --- Bill.com (v3 API, session-based auth) ---
BILLDOTCOM_DEV_KEY=
BILLDOTCOM_ORG_ID=
BILLDOTCOM_USERNAME=
BILLDOTCOM_PASSWORD=
BILLDOTCOM_ENVIRONMENT=sandbox   # sandbox (stage) | production

# --- Bank balances (Plaid) ---
# Balances-only sync: Link a bank, then pull live balances that fill the
# tracked accounts by last-four. Docs: docs/PLAID.md.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | production. Plaid retired the standalone "development" env — use
# production for live banks (secret differs per env).
PLAID_ENV=sandbox
# Required for OAuth banks (Chase, Wells Fargo, Capital One, …). Must EXACTLY
# match an Allowed redirect URI registered in the Plaid dashboard. Point it at
# the app's /plaid-oauth page. Production must be https.
PLAID_REDIRECT_URI=http://localhost:3000/plaid-oauth
# Optional. Products requested at Link time (comma-separated). Defaults to
# "transactions" — balances ride along automatically (we only read balances;
# no transactions are pulled). "balance" alone is rejected by Plaid. Set this to
# whatever product your account has enabled, e.g. PLAID_PRODUCTS=auth
PLAID_PRODUCTS=transactions

# --- CRM (our own DB / internal API) ---
CRM_DATABASE_URL=
CRM_API_BASE_URL=
CRM_API_TOKEN=

# --- Auth: Google SSO via Supabase Auth ---
# The app is gated behind Google sign-in. Only these emails may enter
# (comma-separated, case-insensitive). Fails CLOSED: unset = nobody gets in.
# The Google provider itself is configured in the Supabase dashboard
# (Auth > Providers > Google) — no client id/secret lives here.
AUTH_ALLOWED_EMAILS=you@brainsonfire.com,teammate@brainsonfire.com

# Vercel Cron auth: Vercel sends `Authorization: Bearer $CRON_SECRET` with each
# scheduled request (see vercel.json). Set to any long random string in Vercel.
CRON_SECRET=

# Feature flags — each integration is independently toggleable
SYNC_CRM_ENABLED=false
SYNC_QBO_ENABLED=false
SYNC_BILLDOTCOM_ENABLED=false
SYNC_BANK_ENABLED=false
